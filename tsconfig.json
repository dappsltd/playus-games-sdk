{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@playus.club/games-sdk": ["src/playus/index.ts"],
      "@playus.club/games-sdk/phaser": ["src/playus/engines/phaser/index.ts"],
      "@playus.club/games-sdk/babylon": ["src/playus/engines/babylon/index.ts"],
      "@playus.club/games-sdk/three": ["src/playus/engines/three/index.ts"],
      "@playus.club/games-sdk/overlay": ["src/playus/overlay/index.ts"],
      "@playus.club/games-sdk/*": ["src/playus/*"]
    }
  },
  "include": ["src", "games"]
}
